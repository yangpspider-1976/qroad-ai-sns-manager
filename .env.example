# App
APP_URL=http://localhost:3000
DATABASE_URL=file:./dev.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
NEXTAUTH_SECRET=replace_me
NEXTAUTH_URL=http://localhost:3000

# AI Provider
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=

# Meta API
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v23.0
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback
META_BUSINESS_LOGIN_CONFIG_ID=
META_FACEBOOK_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts

# Instagram Login for Business
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
INSTAGRAM_API_VERSION=v23.0

# TikTok API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish
TIKTOK_POST_MODE=DIRECT_POST
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_AUTO_ADD_MUSIC=false
TIKTOK_BRAND_CONTENT=false
TIKTOK_BRAND_ORGANIC=false

# Storage
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads

# Safety
MOCK_PUBLISHING=true
REQUIRE_APPROVAL_BEFORE_PUBLISH=true
